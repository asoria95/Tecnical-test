# -----------------------------------------------------------------------------
# Multi-microservice repo — line endings and diff behavior
# -----------------------------------------------------------------------------

# Scripts: force LF
gradlew text eol=lf
**/gradlew text eol=lf
*.sh text eol=lf

# Windows scripts: CRLF
*.bat text eol=crlf
**/gradlew.bat text eol=crlf

# Binaries: no diff, no merge
*.jar binary
*.war binary
*.class binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary

# Source and config: text, LF preferred
*.java text eol=lf
*.kt text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.md text eol=lf
*.json text eol=lf
Dockerfile text eol=lf
*.dockerfile text eol=lf
